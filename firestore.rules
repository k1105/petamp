rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 公開プロフィール: 自分自身のみ書き込み可、サインイン済みなら誰でも読める
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow delete: if false;

      // ラン: trail データはフォロワー間で見せ合うのでサインイン済みなら誰でも読める。
      // 書き込みは本人のみ。UI 側でフォローしていないユーザーへの取得はしない。
      match /runs/{runId} {
        allow read: if isSignedIn();
        allow write: if isSelf(uid);
      }

      // FCM デバイストークン: 本人のみ読み書き。
      // プッシュ送信 (api/notify-run) は firebase-admin で読むためルールの対象外。
      match /fcmTokens/{token} {
        allow read, write: if isSelf(uid);
      }

      // キャラ記憶: episodic / semantic / relational / namedPlace を
      // users/{uid}/characters/{characterId}/{kind}/{docId} の階層に保存。
      // 完全に本人プライベート。
      match /characters/{characterId}/{kind}/{docId} {
        allow read, write: if isSelf(uid);
      }
    }

    // 問題報告: ユーザーからの不具合/品質報告。本人のみ作成可、読み書きはコンソール経由。
    match /reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // 相互フレンド関係: doc ID は sorted UID で `${minUid}__${maxUid}`
    // members は同じ 2 つの UID を昇順で並べた配列。これにより A↔B の関係が 1 doc に正規化される。
    match /friends/{friendId} {
      // 単一取得 (isFriendWith など): doc ID から判定するので未存在 doc でも通る
      allow get: if isSignedIn()
        && request.auth.uid in friendId.split('__');

      // クエリ (listMyFriends): where('members','array-contains', uid) の制約と整合させるため
      // resource.data.members を参照する。Firestore が「全結果が条件を満たす」と検証可能になる。
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.members;

      // 作成: 自分が members に含まれ、doc ID が sorted members と一致すること
      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members[0] < request.resource.data.members[1]
        && friendId == request.resource.data.members[0] + '__' + request.resource.data.members[1];

      // 更新: 不要 (members は不変)
      allow update: if false;

      // 削除: 当事者のみ
      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.members;
    }

    // 一緒に走るセッション (coRuns/{sessionId})。
    // GPS は同期しない。開始/終了の同期と参加者の状態共有のためだけに存在する。
    match /coRuns/{sessionId} {
      // 取得/クエリ: 参加者のみ。招待リスナーは
      // where('memberUids','array-contains', uid) && where('status','==','lobby')。
      allow get, list: if isSignedIn()
        && request.auth.uid in resource.data.memberUids;

      // 作成: 呼び出し元が host かつ memberUids に含まれ、status は lobby 始まり。
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.memberUids is list
        && request.resource.data.hostUid in request.resource.data.memberUids
        && request.resource.data.status == 'lobby';

      // 更新: 参加者のみ。membership は不変。
      // status を変更できるのは host だけ (開始/終了ゲートのフリップ)。
      // 非 host は自分の members エントリ更新のみ (status 据え置き)。
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.memberUids
        && request.resource.data.memberUids == resource.data.memberUids
        && request.resource.data.hostUid == resource.data.hostUid
        && (
          resource.data.hostUid == request.auth.uid
          || request.resource.data.status == resource.data.status
        );

      // 削除: host のみ。
      allow delete: if isSignedIn()
        && resource.data.hostUid == request.auth.uid;
    }
  }
}
