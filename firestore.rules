rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // 公開プロフィール: 自分自身のみ書き込み可、サインイン済みなら誰でも読める
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid)
        && request.resource.data.uid == uid;
      allow delete: if false;

      // ラン: trail データはフォロワー間で見せ合うのでサインイン済みなら誰でも読める。
      // 書き込みは本人のみ。UI 側でフォローしていないユーザーへの取得はしない。
      match /runs/{runId} {
        allow read: if isSignedIn();
        allow write: if isSelf(uid);
      }

      // キャラ記憶: episodic / semantic / relational / namedPlace を
      // users/{uid}/characters/{characterId}/{kind}/{docId} の階層に保存。
      // 完全に本人プライベート。
      match /characters/{characterId}/{kind}/{docId} {
        allow read, write: if isSelf(uid);
      }
    }

    // 相互フレンド関係: doc ID は sorted UID で `${minUid}__${maxUid}`
    // members は同じ 2 つの UID を昇順で並べた配列。これにより A↔B の関係が 1 doc に正規化される。
    match /friends/{friendId} {
      // 単一取得 (isFriendWith など): doc ID から判定するので未存在 doc でも通る
      allow get: if isSignedIn()
        && request.auth.uid in friendId.split('__');

      // クエリ (listMyFriends): where('members','array-contains', uid) の制約と整合させるため
      // resource.data.members を参照する。Firestore が「全結果が条件を満たす」と検証可能になる。
      allow list: if isSignedIn()
        && request.auth.uid in resource.data.members;

      // 作成: 自分が members に含まれ、doc ID が sorted members と一致すること
      allow create: if isSignedIn()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members[0] < request.resource.data.members[1]
        && friendId == request.resource.data.members[0] + '__' + request.resource.data.members[1];

      // 更新: 不要 (members は不変)
      allow update: if false;

      // 削除: 当事者のみ
      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.members;
    }
  }
}
